<div class="px-4 md:px-12 max-w-[1920px] mx-auto py-10">

  <div class="mb-6">
    <%= render partial: 'common/ads/horizontal_ad' %>
  </div>

  <% if current_user && !current_user.confirmed? %>
    <div class="mb-6 bg-yellow-950/40 border border-yellow-700/50 text-yellow-300 px-5 py-4 rounded-xl">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-yellow-400">mail</span>
        <p class="text-sm">Please check your email and confirm your address to complete your registration.</p>
      </div>
    </div>
  <% end %>

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="material-symbols-outlined text-[#D7DF21] text-3xl">article</span>
      <h2 class="font-['Space_Grotesk'] text-2xl font-bold text-[#D7DF21] uppercase tracking-widest">Articles</h2>
    </div>
    <div class="h-px bg-gradient-to-r from-[#D7DF21]/40 via-[#484833]/30 to-transparent mt-4"></div>
  </div>

  <%
  unless @articles.blank?
  %>

  <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-5 mb-8">
    <p class="text-[#dfe2eb] text-sm"><strong class="text-[#D7DF21]">Do you want to get involved?</strong>
    If you want to share your work or experience here, feel free to <a href="mailto:ufohunterscom@gmail.com" class="text-[#bdf4ff] hover:text-[#D7DF21] transition-colors underline">contact us!</a> or join our <%= link_to('UFO Research Network', {:controller => "articles", :action => "uforesearchteam"}, class: "text-[#bdf4ff] hover:text-[#D7DF21] transition-colors underline")%></p>
  </div>

  <div class="w-full lg:w-2/3" itemscope itemtype="http://schema.org/ItemList">
    <meta itemprop="itemListOrder" content="Descending"/>
    <%
    @articles.each do |article| %>
    <div class="flex flex-col sm:flex-row gap-5 mb-6 p-5 bg-[#262a31] border border-[#484833]/20 rounded-xl hover:border-[#484833]/40 transition" itemprop="itemListElement" itemscope itemtype="http://schema.org/Article">

      <article class="flex flex-col sm:flex-row gap-5 w-full">
        <meta itemprop="articleSection" content="Articles">
        <%
        unless article.image_thumbnail.blank?
        %>
        <div class="w-full sm:w-1/4 flex-shrink-0">
          <figure>
            <%= image_tag(article.image_thumbnail, :itemprop => "image", :title => article.title, :alt => article.title, :class => "rounded-lg border border-[#484833]/30 w-full h-auto")%>
          </figure>
        </div>
        <div class="flex-1">
        <%
        else
        %>
        <div class="w-full">
        <%
        end
        %>
          <header>
            <h3 itemprop="name" class="text-xl font-semibold text-[#D7DF21] hover:text-[#bdf4ff] transition-colors"><%= link_to article.title, :controller => "articles", :action => "show", :id => article.id, :title => ArticlesHelper.friendly_title(article) %></h3>
          </header>
          <p class="text-sm text-[#c9c8ad] mt-2">
            <small>Published on <strong itemprop="dateCreated" content="<%= format_date_microdata article.published_date %>" class="text-[#dfe2eb]"><%= format_date article.published_date %></strong><br/>
              <meta itemprop="datePublished" content="<%= format_date_microdata article.published_date %>">
              By: <span itemprop="author" itemscope itemtype="http://schema.org/Organization"><strong itemprop="name" class="text-[#dfe2eb]"><%=article.user.username%></strong></span>
              <span itemprop="publisher" itemscope itemtype="http://schema.org/Organization">
                <meta itemprop="name" content="ufo-hunters.com">
              </span>
            </small>
          </p>
          <div class="mt-3 text-[#dfe2eb] text-sm leading-relaxed">
            <p itemprop="description"><%= sanitize_article article.teaser %></p>
          </div>
          <div class="mt-4 flex gap-3">
            <%= link_to 'Edit', edit_article_path(article), class: "inline-flex items-center gap-1 px-4 py-2 bg-[#D7DF21] text-[#313300] text-xs font-['Space_Grotesk'] uppercase tracking-widest font-bold rounded-lg hover:bg-[#D7DF21] transition-colors" if logged_in? %>
            <%= link_to 'Destroy', article, confirm: 'Are you sure?', class: "inline-flex items-center gap-1 px-4 py-2 bg-red-600/80 text-white text-xs font-['Space_Grotesk'] uppercase tracking-widest font-bold rounded-lg hover:bg-red-700 transition-colors", method: :delete if logged_in? %>
          </div>
        </div>

      </article>

    </div>
    <%
    end
    %>
  </div>

  <%= render partial: 'common/ads/adaptable' %>

  <%
  else
  %>
  <div class="bg-[#262a31] border border-[#484833]/20 text-[#c9c8ad] px-5 py-4 rounded-xl" role="alert">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-[#bdf4ff]">info</span>
      <span>No content available</span>
    </div>
  </div>
  <%
  end
  %>

  <!-- Create article CTA -->
  <div class="mt-8">
    <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-6">
      <p class="text-[#dfe2eb] mb-4"><strong class="text-[#D7DF21]">Are you ready?</strong> Create your article here: <%= link_to 'New Article', new_article_path, class: "bg-[#D7DF21] text-[#313300] hover:bg-[#D7DF21] font-['Space_Grotesk'] uppercase tracking-widest font-bold py-2 px-6 rounded-lg transition-colors duration-200 inline-block" if logged_in? %></p>
      <div class="bg-[#0a0e14] border border-[#D7DF21]/20 text-[#D7DF21]/80 px-5 py-4 rounded-lg">
        <div class="flex items-start gap-2">
          <span class="material-symbols-outlined text-[#D7DF21] mt-0.5">warning</span>
          <p class="text-sm">Contents in the "Articles" section are moderated BEFORE they appear on the site, and this takes time... We thank you for your patience and understanding.</p>
        </div>
      </div>
    </div>
  </div>

</div>
