<div class="px-4 md:px-12 max-w-[600px] mx-auto py-16">
  <h1 class="text-3xl font-bold font-['Space_Grotesk'] uppercase tracking-widest text-[#dfe2eb] mb-8 text-center">Reset Password</h1>

  <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-8">
    <p class="text-[#c9c8ad] text-sm mb-6 leading-relaxed">
      Enter your email address and we'll send you a link to reset your password.
    </p>

    <%= form_with url: password_resets_path, method: :post, local: true do |f| %>
      <div class="mb-6">
        <%= f.label :email, class: "font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block" %>
        <%= f.email_field :email, required: true, class: "w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none", placeholder: "your@email.com" %>
      </div>

      <div>
        <%= f.submit "Send Reset Link", class: "w-full bg-[#D7DF21] text-[#313300] hover:bg-[#e8ef32] font-['Space_Grotesk'] uppercase tracking-widest font-bold py-3 px-8 rounded-lg cursor-pointer transition-colors duration-200" %>
      </div>
    <% end %>

    <p class="mt-6 text-center">
      <%= link_to "Back to login", articles_uforesearchteam_path, class: "text-[#bdf4ff] hover:underline text-sm" %>
    </p>
  </div>
</div>
