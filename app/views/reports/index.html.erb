<h1 class="text-2xl font-bold text-white mb-6">Recent Reports</h1>

<div class="overflow-x-auto">
  <table class="w-full text-left text-gray-300">
    <thead class="bg-gray-800 text-[#D7DF21] text-sm uppercase">
      <tr>
        <th class="px-4 py-3">Sighted At</th>
        <th class="px-4 py-3">Location</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-700">
    <% @reports.each do |report| %>
      <tr class="hover:bg-gray-800/50 transition">
        <td class="px-4 py-3"><%= report.sighted_at %></td>
        <td class="px-4 py-3"><%= report.location %></td>
        <td class="px-4 py-3"><%= link_to 'View', report, class: "text-[#D7DF21]" %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>
