<script src="http://code.jquery.com/ui/1.10.2/jquery-ui.js"></script>
<link rel="stylesheet" href="http://code.jquery.com/ui/1.10.2/themes/smoothness/jquery-ui.css" />
<script src='https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v2.3.0/mapbox-gl-geocoder.min.js'></script>
<link rel='stylesheet' href='https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v2.3.0/mapbox-gl-geocoder.css' type='text/css' />

<script>
   $(document).ready(function(){
        $("#new_report").validate({
       });
   });
</script>
<div class="mb-4">
   <h3 class="text-xl font-semibold text-[#D7DF21]">New report</h3>
</div>
<%= form_for(@report) do |f| %>
<div>
   <div class="w-full">
      <% if @report.errors.any? %>
      <div id="error_explanation" class="mb-4 bg-red-900/50 border border-red-700 text-red-300 px-4 py-3 rounded">
         <h2 class="font-semibold mb-2"><%= pluralize(@report.errors.count, "error") %> prohibited this report from being saved:</h2>
         <ul class="list-disc list-inside">
            <% @report.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
            <% end %>
         </ul>
      </div>
      <% end %>
   </div>
</div>
<script>
   $(function() {
     $( "#report_sighted_at" ).datepicker({dateFormat: "mm/dd/yy"});
   });
   cont = 0;
   function addlink() {
           cont = cont + 1;
            $(".fieldlinks").append("<input type='text' size='30' class='w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21] mt-2' name='report[links][]' id='report_links_" + cont + "'/>");
   }
</script>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
   <div>
      <label for="sighted_at" class="block text-sm font-medium text-gray-300 mb-1">Sighted on <span class="text-red-500">*</span></label>
      <%
         sighted_at_value = nil
         unless params[:report].blank?
           sighted_at_value = params[:report]["sighted_at"]
         end
         %>
      <%= f.text_field :sighted_at, :size => 12, :class => 'w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21]', :value => sighted_at_value %>
   </div>
   <%
      reported_at_value = Time.new.strftime('%m/%d/%Y').to_s
      %>
   <%= f.hidden_field :reported_at, :value => reported_at_value %>
   <div>
      <label for="report_shape" class="block text-sm font-medium text-gray-300 mb-1">Shape <span class="text-red-500">*</span></label>
      <%= f.text_field :shape, :size => 12, :class => 'w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21]' %>
   </div>
   <div>
      <label for="report_duration" class="block text-sm font-medium text-gray-300 mb-1">Duration <span class="text-red-500">*</span></label>
      <%= f.text_field :duration, :size => 12, :class => 'w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21]' %>
   </div>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
   <div>
      <label for="report_email" class="block text-sm font-medium text-gray-300 mb-1">Contact email (your email address will never be published or shared)</label>
      <%= f.text_field :email, :class => 'w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21]' %>
   </div>
   <div>
      <label for="report_email_confirmation" class="block text-sm font-medium text-gray-300 mb-1">Contact email confirmation (repeat your email to make sure it is OK)</label>
      <%= f.text_field :email_confirmation, :class => 'w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21]' %>
   </div>
   <div>
      <label for="report_links" class="block text-sm font-medium text-gray-300 mb-1">Links (videos, images, articles...)</label>
      <input id="report_links_0" class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21]" type="text" size="30" name="report[links][]">
      <div class="fieldlinks"></div>
      <a href="javascript:addlink();" class="text-[#D7DF21] text-sm hover:underline mt-1 inline-block">(Add more links)</a>
   </div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
   <div>
      <label for="report_location" class="block text-sm font-medium text-gray-300 mb-1">Location <span class="text-red-500">*</span></label>
      <%= f.text_field :location, :class => 'w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21]' %>
      <div id="map-canvas" class="map-canvas mt-2 rounded-lg overflow-hidden" style="height: 300px;"></div>
   </div>
   <div>
      <label for="report_description" class="block text-sm font-medium text-gray-300 mb-1">Description <span class="text-red-500">*</span></label>
      <%= f.text_area :description, :rows => 8, :cols => 84, :class => 'w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white focus:outline-none focus:border-[#D7DF21] resize-y' %>
   </div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
   <div>
      <%= flash[:recaptcha_error] %>
      <% if ENV['RECAPTCHA_SITE_KEY'].present? %>
        <%= recaptcha_tags %>
      <% else %>
        <p class="text-yellow-400 text-sm">[reCAPTCHA disabled — RECAPTCHA_SITE_KEY not set]</p>
      <% end %>
   </div>
   <div>
      <input type="submit" class="px-6 py-3 bg-[#D7DF21] text-gray-900 font-bold rounded hover:bg-[#c5cd1e] transition cursor-pointer mt-5" value="SEND UFO'S REPORT" name="commit">
   </div>
   <div name="coord_div" id="coord_div" class="required" style="visibility: hidden;"></div>
   <input type="hidden" size="30" name="report[coord]" id="report_coord" class="fieldufo">
</div>
<% end %>

<script>
	mapboxgl.accessToken = 'pk.eyJ1IjoiZmpmZGVwZWRybyIsImEiOiJjam40bWswc3k1ZmgwM3BueG45YXZoZ3MwIn0.LpHFrAER3JjOAZwnyDnrqw';
	var map = new mapboxgl.Map({
	    container: 'map-canvas',
	    style: 'mapbox://styles/fjfdepedro/cjnc849ms0g6l2rsc5edfb4gl',
	    center: [-73.98,40.76],
	    zoom: 7
	});

	var geocoder = new MapboxGeocoder({
	    accessToken: mapboxgl.accessToken
	});

	map.addControl(geocoder);

	// After the map style has loaded on the page, add a source layer and default
	// styling for a single point.
	map.on('load', function() {
	    map.addSource('single-point', {
	        "type": "geojson",
	        "data": {
	            "type": "FeatureCollection",
	            "features": []
	        }
	    });


	    map.addLayer({
	        "id": "point",
	        "source": "single-point",
	        "type": "circle",
	        "paint": {
	            "circle-radius": 10,
	            "circle-color": "#ff0000"
	        }
	    });

      // Listen for the `geocoder.input` event that is triggered when a user
    // makes a selection and add a symbol that matches the result.
    geocoder.on('result', function(ev) {
        map.getSource('single-point').setData(ev.result.geometry);
        var styleSpec = ev.result;
        var styleSpecBox = document.getElementById('coord_div');
        var styleSpecText = JSON.stringify(styleSpec, null, 2);
        var syntaxStyleSpecText = syntaxHighlight(styleSpecText);
        styleSpecBox.innerHTML = syntaxStyleSpecText;

        document.getElementById('report_coord').value = syntaxStyleSpecText;

    });


	});

  function syntaxHighlight(json) {
    var obj = JSON.parse(json);
    return obj.center
  }
</script>
