<h1 class="text-2xl font-bold text-white mb-6">Nearest sightings</h1>

<div class="overflow-x-auto">
  <table class="w-full text-left text-gray-300">
    <thead class="bg-gray-800 text-[#D7DF21] text-sm uppercase">
      <tr>
        <th class="px-4 py-3">Sighted At</th>
        <th class="px-4 py-3"></th>
        <th class="px-4 py-3"></th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-700">
    <% @nearest.each do |report| %>
      <tr class="hover:bg-gray-800/50 transition">
        <td class="px-4 py-3"><%= report.sighted_at %></td>
        <td class="px-4 py-3"><%= link_to 'Show', report, class: "text-[#D7DF21] hover:underline" %></td>
        <td class="px-4 py-3"><%= link_to 'Edit', edit_report_path(report), class: "text-[#D7DF21] hover:underline" %></td>
        <td class="px-4 py-3"><%= link_to 'Destroy', report, confirm: 'Are you sure?', method: :delete, class: "text-red-400 hover:underline" %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>

<div class="mt-6">
  <%= link_to 'New Ufo model', new_report_path, class: "inline-block px-4 py-2 bg-[#D7DF21] text-gray-900 font-semibold rounded hover:bg-[#c5cd1e] transition" %>
</div>
