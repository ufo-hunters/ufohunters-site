<div class="max-w-3xl mx-auto">

  <div class="mb-6">
    <h3 class="text-2xl font-bold text-[#D7DF21] mb-4">New ufo reported!</h3>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div>
      <label for="sighted_at" class="block text-sm font-medium text-gray-400"><strong class="text-white">Sighted on </strong></label>
      <p class="text-gray-300 mt-1"><%= format_date @report['sighted_at']%></p>
    </div>
    <div>
      <label for="reported_at" class="block text-sm font-medium text-gray-400"><strong class="text-white">Reported on </strong></label>
      <p class="text-gray-300 mt-1"><%= format_date @report['reported_at']%></p>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div>
      <label for="report_shape" class="block text-sm font-medium text-gray-400"><strong class="text-white">Shape </strong></label>
      <p class="text-gray-300 mt-1"><%= @report['shape']%></p>
    </div>
    <div>
      <label for="report_duration" class="block text-sm font-medium text-gray-400"><strong class="text-white">Duration </strong></label>
      <p class="text-gray-300 mt-1"><%= @report['duration']%></p>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div>
      <label for="report_location" class="block text-sm font-medium text-gray-400"><strong class="text-white">Location </strong></label>
      <p class="text-gray-300 mt-1"><%= @report['location']%></p>
    </div>
    <% unless @report['links'].blank? || @report['links'].size == 0 || @report['links'][0].blank? %>
    <div>
      <label for="report_links" class="block text-sm font-medium text-gray-400"><strong class="text-white">Links </strong></label>
      <p class="text-gray-300 mt-1"><%= @report['links'].map { |i| "'" + i.to_s + "'" }.join(",")%></p>
    </div>
    <% end %>
  </div>
  <div class="mb-4">
    <div class="w-full">
      <label for="report_description" class="block text-sm font-medium text-gray-400"><strong class="text-white">Description </strong></label>
      <p class="text-gray-300 mt-1"><%= @report['description']%> </p>
    </div>
  </div>
  <% unless @report['image_imagekit'].blank? %>
  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-400"><strong class="text-white">Uploaded Images</strong></label>
    <div class="flex gap-2 mt-2 flex-wrap">
      <% @report['image_imagekit'].each do |img_url| %>
        <a href="<%= img_url %>" target="_blank">
          <img src="<%= img_url %>?tr=w-200" alt="Uploaded image" class="w-48 h-auto rounded border border-gray-700" />
        </a>
      <% end %>
    </div>
  </div>
  <% end %>
  <div class="mt-6">
    <div class="w-full text-center text-[#D7DF21] text-xl font-semibold py-4 bg-gray-800/60 border border-gray-700 rounded-lg">
      Thank you very much for your trust in us
    </div>
  </div>
</div>
