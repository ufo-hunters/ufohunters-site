
<div class="w-full mb-4">
  <h3 class="text-xl font-bold text-[#D7DF21]">Latest sightings in <%= @country_name %></h3>
</div>

<div class="w-full mb-4">
  <div id="sightings-map" class="w-full h-[450px] rounded-lg"></div>
</div>

<%= render partial: 'common/map', locals: {ufo_list: @ufo_list, map_id: 'sightings-map', map_zoom: (@zoom.to_i-1), map_center: [ @country_coord[0],@country_coord[1]]} %>

<div class="my-5">
  <%= render partial: 'common/ads/horizontal_ad' %>
</div>

<% if @ufo_list.empty? %>
  <div class="w-full">
    <div class="bg-yellow-900/30 border border-yellow-600 rounded-lg p-6">
      <h2 class="text-xl font-bold text-yellow-300">Sorry... we haven't got any sightings reported in <strong><%= @country_name %></strong></h2>
      <h3 class="text-lg mt-2 text-gray-300">If you saw a UFO, please <%= link_to "let us know", new_report_path, class: "text-[#D7DF21] hover:underline" %>!!</h3>
    </div>
  </div>
<% end %>

<% unless @ufo_list.empty? %>
  <div class="w-full mb-4">
    <h3 class="text-xl font-bold text-gray-200">Latest UFO sightings in <%= @country_name %>:</h3>
  </div>

  <div class="grid grid-cols-12 gap-4">
    <div class="col-span-12 lg:col-span-8">
      <%= render partial: 'common/latest_sightings' %>
    </div>
    <div class="col-span-12 lg:col-span-4">
      <%= render partial: 'common/ads/adaptable3' %>
    </div>
  </div>
<% end %>
