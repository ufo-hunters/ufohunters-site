
<!-- Country Header -->
<section class="px-4 md:px-12 max-w-[1920px] mx-auto pt-10 pb-6">
  <p class="uppercase tracking-widest text-[10px] font-['Space_Grotesk'] text-[#bdf4ff] mb-2">Country Sightings</p>
  <h3 class="text-3xl md:text-4xl font-bold font-['Space_Grotesk'] uppercase tracking-widest text-[#D7DF21] drop-shadow-[0_0_8px_rgba(215,223,33,0.5)]"><%= @country_name %></h3>
</section>

<!-- Sightings Map -->
<section class="px-4 md:px-12 max-w-[1920px] mx-auto mb-6">
  <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-4">
    <div id="sightings-map" class="w-full h-[450px] rounded-lg overflow-hidden"></div>
  </div>
</section>

<%= render partial: 'common/map', locals: {ufo_list: @ufo_list, map_id: 'sightings-map', map_zoom: (@zoom.to_i-1), map_center: [ @country_coord[0],@country_coord[1]]} %>

<div class="px-4 md:px-12 max-w-[1920px] mx-auto my-5">
  <%= render partial: 'common/ads/horizontal_ad' %>
</div>

<% if @ufo_list.empty? %>
  <section class="px-4 md:px-12 max-w-[1920px] mx-auto pb-10">
    <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-8 border-l-4 border-l-[#D7DF21]">
      <h2 class="text-xl font-bold font-['Space_Grotesk'] uppercase tracking-widest text-[#D7DF21] mb-3">No sightings reported</h2>
      <p class="text-[#dfe2eb] text-lg">We haven't got any sightings reported in <strong class="text-[#bdf4ff]"><%= @country_name %></strong> yet.</p>
      <p class="text-[#c9c8ad] mt-3">If you saw a UFO, please <%= link_to "let us know", new_report_path, class: "text-[#bdf4ff] hover:text-[#D7DF21] transition-colors font-semibold underline" %>!</p>
    </div>
  </section>
<% end %>

<% unless @ufo_list.empty? %>
  <section class="px-4 md:px-12 max-w-[1920px] mx-auto pb-10">
    <div class="mb-6 border-l-4 border-[#D7DF21] pl-4">
      <p class="uppercase tracking-widest text-[10px] font-['Space_Grotesk'] text-[#c9c8ad] mb-1">Database</p>
      <h3 class="text-xl font-bold font-['Space_Grotesk'] uppercase tracking-widest text-[#dfe2eb]">Latest UFO Sightings in <%= @country_name %></h3>
    </div>

    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-8">
        <%= render partial: 'common/latest_sightings' %>
      </div>
      <div class="col-span-12 lg:col-span-4">
        <%= render partial: 'common/ads/adaptable3' %>
      </div>
    </div>
  </section>
<% end %>
