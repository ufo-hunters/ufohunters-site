<%= render 'common/maplibre_head' %>

<div class="px-4 md:px-12 max-w-[1920px] mx-auto py-10">

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="material-symbols-outlined text-[#D7DF21] text-3xl">terminal</span>
      <h3 class="font-['Space_Grotesk'] text-2xl font-bold text-[#D7DF21] uppercase tracking-widest">Archive Search</h3>
    </div>
    <div class="h-px bg-gradient-to-r from-[#D7DF21]/40 via-[#484833]/30 to-transparent mb-6"></div>
  </div>

  <!-- Instructions card -->
  <details class="bg-[#262a31] border border-[#484833]/20 rounded-xl mb-8 group" open>
    <summary class="flex items-center gap-2 p-6 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
      <span class="material-symbols-outlined text-[#bdf4ff] text-xl">info</span>
      <span class="font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad]">How to search</span>
      <span class="material-symbols-outlined text-[#c9c8ad] text-sm ml-auto transition-transform duration-200 group-open:rotate-180">expand_more</span>
    </summary>
    <div class="space-y-2 text-[#dfe2eb] text-sm leading-relaxed px-6 pb-6">
      <p>First of all, thank you very much for using our UFO search engine. Here you can search our huge database, choosing a location and a date range.</p>
      <p>The search will be performed between the dates chosen, around the location (<span class="text-[#bdf4ff] underline">within a radius of 200 miles from the selected location</span>).</p>
      <p>In the <strong class="text-[#D7DF21]">Start Date</strong> field, please select the starting date from which you want to perform your query. The <strong class="text-[#D7DF21]">End Date</strong> field indicates the upper limit for your date range.</p>
      <p>Finally, fill in the <strong class="text-[#D7DF21]">search</strong> box, inside the map, the sighting location.</p>
      <p>Just below the map, type in the captcha field the letters you see in the image, and click on <strong class="text-[#D7DF21]">SEARCH UFOS</strong> to get the results.</p>
    </div>
  </details>
  <script>
    (function() {
      var details = document.querySelector('details.group');
      if (details && window.innerWidth < 768) {
        details.removeAttribute('open');
      }
    })();
  </script>

  <%= form_tag('/sightings/ufosearchresults', method: :get, id: 'ufosearch', name: 'ufosearch', data: { turbo: false }) do %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      <div>
        <label for="startdate" class="font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block">Start Date <span class="text-red-500">*</span></label>
        <input type="date" id="startdate" style="color-scheme: dark" name="startdate" class="w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none" required>
      </div>
      <div>
        <label for="enddate" class="font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block">End Date <span class="text-red-500">*</span></label>
        <input type="date" id="enddate" style="color-scheme: dark" name="enddate" class="w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none" required>
      </div>
      <div>
      </div>
    </div>

    <!-- Map -->
    <div class="w-full mb-6" data-controller="geocoder" data-geocoder-lat-value="40.76" data-geocoder-lon-value="-73.98" data-geocoder-zoom-value="7">
      <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-4">
        <label class="font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block">Location <span class="text-red-500">*</span> <span class="normal-case text-[#484833]">(search or click on map)</span></label>
        <input data-geocoder-target="search" data-action="input->geocoder#search" type="text" placeholder="Search location on map..." class="w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none text-sm mb-3" />
        <div data-geocoder-target="results" class="relative z-50 w-full bg-[#1c2026] border border-[#484833]/30 rounded-lg max-h-48 overflow-y-auto hidden mb-3"></div>
        <div data-geocoder-target="map" class="w-full h-[400px] rounded-lg"></div>
        <input type="hidden" data-geocoder-target="coord" name="coord" id="coord"/>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <% if ENV['RECAPTCHA_SITE_KEY'].present? %>
          <%= recaptcha_tags %>
        <% else %>
          <p class="text-[#D7DF21]/60 text-sm">[reCAPTCHA disabled — RECAPTCHA_SITE_KEY not set]</p>
        <% end %>
        <div class="mt-2"><span class="text-red-400 text-sm"><%= flash[:recaptcha_error] %></span></div>
      </div>
      <div class="flex items-center">
        <input type="submit" class="bg-[#D7DF21] text-[#313300] hover:bg-[#D7DF21] font-['Space_Grotesk'] uppercase tracking-widest font-bold py-3 px-8 rounded-lg cursor-pointer transition-colors duration-200" value="SEARCH UFOS" name="commit">
      </div>
    </div>

  <% end %>

</div>

