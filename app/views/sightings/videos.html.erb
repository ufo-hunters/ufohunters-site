<% cache("videos/content", expires_in: 12.hours) do %>

<div class="px-4 md:px-12 max-w-[1920px] mx-auto py-10">

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="material-symbols-outlined text-[#D7DF21] text-3xl">video_library</span>
      <h1 class="font-['Space_Grotesk'] text-2xl font-bold text-[#D7DF21] uppercase tracking-widest">UFO Video Gallery</h1>
    </div>
    <p class="text-[#dfe2eb] text-sm">Discover the latest UFO sightings videos all over the world</p>
    <div class="h-px bg-gradient-to-r from-[#D7DF21]/40 via-[#484833]/30 to-transparent mt-4"></div>
  </div>

  <div class="my-6">
    <%= render partial: 'common/ads/adaptable3', locals: {span: 'w-full'} %>
  </div>

  <!-- Video Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <%
      @ufo_list.each do |ufo|
        video_urls, other_urls = select_youtube_videos(ufo.links)

        unless video_urls.blank?
          video_urls.each do |vid|
            video_id = youtube_video_id(vid)
            next if video_id.blank?
    %>
            <div class="group">
              <div class="relative aspect-video rounded-xl overflow-hidden border border-[#484833]/20 hover:border-[#D7DF21]/40 transition-all mb-3">
                <%= link_to sightings_search_path(id: ufo.id, title: friendly_title(ufo)), class: "block w-full h-full relative no-underline" do %>
                  <img src="<%= Ufo::THUMBS_URL_BASE + video_id + '/0.jpg' %>" alt="<%= ufo.location %>" loading="lazy" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-16 h-16 rounded-full bg-[#D7DF21]/80 flex items-center justify-center group-hover:bg-[#D7DF21] group-hover:scale-110 transition-all">
                      <span class="material-symbols-outlined text-[#313300] text-3xl ml-1">play_arrow</span>
                    </div>
                  </div>
                <% end %>
              </div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[#D7DF21] font-['Space_Grotesk'] text-[10px] font-bold uppercase tracking-widest truncate"><%= ufo.location %></span>
                <span class="text-[#c9c8ad]/30 text-[10px]">&bull;</span>
                <span class="text-[#c9c8ad]/50 text-[10px] font-['Space_Grotesk'] uppercase tracking-wider"><%= format_date ufo.sighted_at %></span>
              </div>
              <p class="text-[#dfe2eb] text-sm font-['Space_Grotesk'] group-hover:text-[#D7DF21] transition-colors truncate"><%= friendly_title(ufo) %></p>
            </div>
    <%
          end
        end
      end
    %>
  </div>

</div>

<div class="px-4 md:px-12 max-w-[1920px] mx-auto">
  <div class="my-6">
    <%= render partial: 'common/ads/horizontal_ad' %>
  </div>
</div>

<% end %>
