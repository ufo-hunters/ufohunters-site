<%= javascript_include_tag "d3.v3.min" %>
<%= javascript_include_tag "d3.geo" %>

<!-- Maps Directory Header -->
<section class="px-4 md:px-12 max-w-[1920px] mx-auto pt-10 pb-6">
  <p class="uppercase tracking-widest text-[10px] font-['Space_Grotesk'] text-[#bdf4ff] mb-2">Global Coverage</p>
  <h2 class="text-3xl md:text-4xl font-bold font-['Space_Grotesk'] uppercase tracking-widest text-[#D7DF21] drop-shadow-[0_0_8px_rgba(215,223,33,0.5)]">Maps Directory</h2>
  <p class="mt-3 text-[#dfe2eb] max-w-2xl">Investigate the latest sightings in your continent or region by clicking on the names below.</p>
</section>

<!-- Continent Cards Carousel -->
<% cache("maps/content/continents") do %>
<section class="px-4 md:px-12 max-w-[1920px] mx-auto mb-10">
  <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-6">
    <p class="uppercase tracking-widest text-[10px] font-['Space_Grotesk'] text-[#c9c8ad] mb-4">Continents</p>
    <div id="thumb_continent" class="relative overflow-hidden">
      <div class="carousel-inner w-full md:w-4/5 mx-auto">

        <div class="continent-slide active">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 py-4">
            <div class="group text-center bg-[#0a0e14] rounded-xl p-5 border border-[#484833]/20 hover:border-[#D7DF21]/30 transition-all duration-300">
              <%= image_tag image_path('noord-amerika.png'), class: "mx-auto rounded-lg opacity-90 group-hover:opacity-100 transition-opacity", loading: "lazy", alt: "North America UFO sightings" %>
              <h3 class="text-lg font-bold font-['Space_Grotesk'] uppercase tracking-widest mt-4"><%= link_to "North America", sightings_northamerica_path, class: "text-[#bdf4ff] hover:text-[#D7DF21] transition-colors" %></h3>
            </div>
            <div class="group text-center bg-[#0a0e14] rounded-xl p-5 border border-[#484833]/20 hover:border-[#D7DF21]/30 transition-all duration-300">
              <%= image_tag image_path('zuid-amerika.png'), class: "mx-auto rounded-lg opacity-90 group-hover:opacity-100 transition-opacity", loading: "lazy", alt: "South America UFO sightings" %>
              <h3 class="text-lg font-bold font-['Space_Grotesk'] uppercase tracking-widest mt-4"><%= link_to "South America", sightings_southamerica_path, class: "text-[#bdf4ff] hover:text-[#D7DF21] transition-colors" %></h3>
            </div>
            <div class="group text-center bg-[#0a0e14] rounded-xl p-5 border border-[#484833]/20 hover:border-[#D7DF21]/30 transition-all duration-300">
              <%= image_tag image_path('afrika.png'), class: "mx-auto rounded-lg opacity-90 group-hover:opacity-100 transition-opacity", loading: "lazy", alt: "Africa UFO sightings" %>
              <h3 class="text-lg font-bold font-['Space_Grotesk'] uppercase tracking-widest mt-4"><%= link_to "Africa", sightings_africa_path, class: "text-[#bdf4ff] hover:text-[#D7DF21] transition-colors" %></h3>
            </div>
          </div>
        </div>

        <div class="continent-slide hidden">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 py-4">
            <div class="group text-center bg-[#0a0e14] rounded-xl p-5 border border-[#484833]/20 hover:border-[#D7DF21]/30 transition-all duration-300">
              <%= image_tag image_path('azie.png'), class: "mx-auto rounded-lg opacity-90 group-hover:opacity-100 transition-opacity", loading: "lazy", alt: "Asia UFO sightings" %>
              <h3 class="text-lg font-bold font-['Space_Grotesk'] uppercase tracking-widest mt-4"><%= link_to "Asia", sightings_asia_path, class: "text-[#bdf4ff] hover:text-[#D7DF21] transition-colors" %></h3>
            </div>
            <div class="group text-center bg-[#0a0e14] rounded-xl p-5 border border-[#484833]/20 hover:border-[#D7DF21]/30 transition-all duration-300">
              <%= image_tag image_path('europa.png'), class: "mx-auto rounded-lg opacity-90 group-hover:opacity-100 transition-opacity", loading: "lazy", alt: "Europe UFO sightings" %>
              <h3 class="text-lg font-bold font-['Space_Grotesk'] uppercase tracking-widest mt-4"><%= link_to "Europe", sightings_europe_path, class: "text-[#bdf4ff] hover:text-[#D7DF21] transition-colors" %></h3>
            </div>
            <div class="group text-center bg-[#0a0e14] rounded-xl p-5 border border-[#484833]/20 hover:border-[#D7DF21]/30 transition-all duration-300">
              <%= image_tag image_path('oceanie.png'), class: "mx-auto rounded-lg opacity-90 group-hover:opacity-100 transition-opacity", loading: "lazy", alt: "Oceania UFO sightings" %>
              <h3 class="text-lg font-bold font-['Space_Grotesk'] uppercase tracking-widest mt-4"><%= link_to "Oceania", sightings_oceania_path, class: "text-[#bdf4ff] hover:text-[#D7DF21] transition-colors" %></h3>
            </div>
          </div>
        </div>

      </div>
      <button type="button" class="absolute left-0 top-1/2 -translate-y-1/2 bg-[#0a0e14]/80 text-[#D7DF21] px-3 py-2 rounded-r text-2xl hover:bg-[#0a0e14] transition-colors" data-carousel="thumb_continent" data-action="prev" aria-label="Previous">&lsaquo;</button>
      <button type="button" class="absolute right-0 top-1/2 -translate-y-1/2 bg-[#0a0e14]/80 text-[#D7DF21] px-3 py-2 rounded-l text-2xl hover:bg-[#0a0e14] transition-colors" data-carousel="thumb_continent" data-action="next" aria-label="Next">&rsaquo;</button>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      var container = document.getElementById("thumb_continent");
      var slides = container.querySelectorAll(".continent-slide");
      var currentIndex = 0;

      function showSlide(index) {
        slides.forEach(function(s, i) {
          s.classList.toggle("hidden", i !== index);
          s.classList.toggle("active", i === index);
        });
      }

      container.querySelector('[data-action="prev"]').addEventListener("click", function() {
        currentIndex = (currentIndex - 1 + slides.length) % slides.length;
        showSlide(currentIndex);
      });

      container.querySelector('[data-action="next"]').addEventListener("click", function() {
        currentIndex = (currentIndex + 1) % slides.length;
        showSlide(currentIndex);
      });

      setInterval(function() {
        currentIndex = (currentIndex + 1) % slides.length;
        showSlide(currentIndex);
      }, 5000);
    });
  </script>
</section>
<% end %>

<div class="px-4 md:px-12 max-w-[1920px] mx-auto my-5">
  <%= render partial: 'common/ads/horizontal_ad' %>
</div>

<!-- Interactive Globe -->
<section class="px-4 md:px-12 max-w-[1920px] mx-auto hidden sm:block mb-10">
  <style type="text/css">
    #bodyworld svg {
      width: 1280px;
      height: 800px;
      pointer-events: all;
    }
    #bodyworld circle {
      fill: #00e3fd;
    }
    #bodyworld path {
      fill: #31353c;
      stroke: #484833;
    }
    #bodyworld path:hover {
      fill: #D7DF21;
      cursor: pointer;
    }
  </style>

  <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-6">
    <p class="uppercase tracking-widest text-[10px] font-['Space_Grotesk'] text-[#c9c8ad] mb-1">Interactive Globe</p>
    <h3 class="text-xl font-bold font-['Space_Grotesk'] uppercase tracking-widest text-[#bdf4ff] mb-3">Countries</h3>
    <p class="text-[#dfe2eb] mb-1">Drag with the mouse to rotate the world map.</p>
    <p class="text-[#c9c8ad] text-sm mb-1">Hover over each country to see its name. Click to explore sightings.</p>

    <div id="bodyworld" class="overflow-x-auto mt-4"></div>
  </div>

  <script type="text/javascript">
    var feature;

    var projection = d3.geo.azimuthal()
        .scale(380)
        .origin([-71.03,42.37])
        .mode("orthographic")
        .translate([640, 400]);

    var circle = d3.geo.greatCircle()
        .origin(projection.origin());

    var scale = {
      orthographic: 380,
      stereographic: 380,
      gnomonic: 380,
      equidistant: 380 / Math.PI * 2,
      equalarea: 380 / Math.SQRT2
    };

    var path = d3.geo.path()
        .projection(projection);

    var svg = d3.select("#bodyworld").append("svg:svg")
        .attr("width", 1280)
        .attr("height", 800)
        .on("mousedown", mousedown)
        .on("mousedown.drag", mousedown);

    d3.json("/json/world-countries.json", function(collection) {
        feature = svg.selectAll("path").data(collection.features).enter().append("svg:path").attr("d", clip).on("click", click);
        feature.append("svg:title").text(function(d) { return d.properties.name; });
    });

    d3.select(window)
        .on("mousemove", mousemove)
        .on("mouseup", mouseup);

    d3.select("select").on("change", function() {
      projection.mode(this.value).scale(scale[this.value]);
      refresh(750);
    });

    var m0,
        o0;

    function mousedown() {
      m0 = [d3.event.pageX, d3.event.pageY];
      o0 = projection.origin();
      d3.event.preventDefault();
    }

    function mousemove() {
      if (m0) {
        var m1 = [d3.event.pageX, d3.event.pageY],
            o1 = [o0[0] + (m0[0] - m1[0]) / 8, o0[1] + (m1[1] - m0[1]) / 8];
        projection.origin(o1);
        circle.origin(o1)
        refresh();
      }
    }

    function mouseup() {
      if (m0) {
        mousemove();
        m0 = null;
      }
    }

    function refresh(duration) {
      (duration ? feature.transition().duration(duration) : feature).attr("d", clip);
    }

    function clip(d) {
        return path(circle.clip(d));
    }

    function click(d) {
      window.location.href = '/sightings/country/' + d.id + '/' + d.properties.name;
    }
  </script>
</section>

