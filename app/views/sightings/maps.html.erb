<%= javascript_include_tag "d3.v3.min" %>
<%= javascript_include_tag "d3.geo" %>

<div class="w-full mb-4">
  <h2 class="text-2xl font-bold text-[#D7DF21]">Latest sightings</h2>
  <p class="mt-2"><strong class="text-gray-200"><u>Continents</u></strong></p>
  <p class="text-gray-300">Investigate the latest sightings in your continent (or region) clicking on the names below</p>
</div>

<% cache("maps/content/continents") do %>
<div class="w-full mb-6">
  <div class="bg-[#1D1D1D] border border-gray-700 rounded-lg p-4">
    <div id="thumb_continent" class="relative overflow-hidden">
      <div class="carousel-inner w-4/5 mx-auto">

        <div class="continent-slide active">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 py-4">
            <div class="text-center">
              <%= image_tag image_path('noord-amerika.png'), class: "mx-auto", loading: "lazy", alt: "North America UFO sightings" %>
              <h3 class="text-lg font-bold mt-2"><%= link_to "North America", sightings_northamerica_path, class: "text-[#D7DF21] hover:underline" %></h3>
            </div>
            <div class="text-center">
              <%= image_tag image_path('zuid-amerika.png'), class: "mx-auto", loading: "lazy", alt: "South America UFO sightings" %>
              <h3 class="text-lg font-bold mt-2"><%= link_to "South America", sightings_southamerica_path, class: "text-[#D7DF21] hover:underline" %></h3>
            </div>
            <div class="text-center">
              <%= image_tag image_path('afrika.png'), class: "mx-auto", loading: "lazy", alt: "Africa UFO sightings" %>
              <h3 class="text-lg font-bold mt-2"><%= link_to "Africa", sightings_africa_path, class: "text-[#D7DF21] hover:underline" %></h3>
            </div>
          </div>
        </div>

        <div class="continent-slide hidden">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 py-4">
            <div class="text-center">
              <%= image_tag image_path('azie.png'), class: "mx-auto", loading: "lazy", alt: "Asia UFO sightings" %>
              <h3 class="text-lg font-bold mt-2"><%= link_to "Asia", sightings_asia_path, class: "text-[#D7DF21] hover:underline" %></h3>
            </div>
            <div class="text-center">
              <%= image_tag image_path('europa.png'), class: "mx-auto", loading: "lazy", alt: "Europe UFO sightings" %>
              <h3 class="text-lg font-bold mt-2"><%= link_to "Europe", sightings_europe_path, class: "text-[#D7DF21] hover:underline" %></h3>
            </div>
            <div class="text-center">
              <%= image_tag image_path('oceanie.png'), class: "mx-auto", loading: "lazy", alt: "Oceania UFO sightings" %>
              <h3 class="text-lg font-bold mt-2"><%= link_to "Oceania", sightings_oceania_path, class: "text-[#D7DF21] hover:underline" %></h3>
            </div>
          </div>
        </div>

      </div>
      <button type="button" class="absolute left-0 top-1/2 -translate-y-1/2 bg-black/50 text-white px-3 py-2 rounded-r text-2xl hover:bg-black/70" data-carousel="thumb_continent" data-action="prev" aria-label="Previous">&lsaquo;</button>
      <button type="button" class="absolute right-0 top-1/2 -translate-y-1/2 bg-black/50 text-white px-3 py-2 rounded-l text-2xl hover:bg-black/70" data-carousel="thumb_continent" data-action="next" aria-label="Next">&rsaquo;</button>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      var container = document.getElementById("thumb_continent");
      var slides = container.querySelectorAll(".continent-slide");
      var currentIndex = 0;

      function showSlide(index) {
        slides.forEach(function(s, i) {
          s.classList.toggle("hidden", i !== index);
          s.classList.toggle("active", i === index);
        });
      }

      container.querySelector('[data-action="prev"]').addEventListener("click", function() {
        currentIndex = (currentIndex - 1 + slides.length) % slides.length;
        showSlide(currentIndex);
      });

      container.querySelector('[data-action="next"]').addEventListener("click", function() {
        currentIndex = (currentIndex + 1) % slides.length;
        showSlide(currentIndex);
      });

      setInterval(function() {
        currentIndex = (currentIndex + 1) % slides.length;
        showSlide(currentIndex);
      }, 5000);
    });
  </script>
</div>
<% end %>

<div class="my-5">
  <%= render partial: 'common/ads/horizontal_ad' %>
</div>

<div class="w-full hidden sm:block">
  <style type="text/css">
    svg {
      width: 1280px;
      height: 800px;
      pointer-events: all;
    }
    circle {
      fill: #1972E5;
    }
    path {
      fill: #698dc5;
      stroke: #fff;
    }
  </style>

  <p class="mt-4"><strong class="text-gray-200"><u>Countries</u></strong></p>
  <p class="text-gray-300">You can move the world!, drag with the mouse (i.e. clicking plus holding the button down and then moving it) the world map.</p>
  <p class="text-gray-300">When you hover the mouse over each one of the countries, a tooltip will appear and will show the country's name.</p>
  <p class="text-gray-300">Discover your country maps by a simple mouse-click on the one which is of interest for you.</p>

  <div id="bodyworld" class="-ml-[180px]"></div>

  <script type="text/javascript">
    var feature;

    var projection = d3.geo.azimuthal()
        .scale(380)
        .origin([-71.03,42.37])
        .mode("orthographic")
        .translate([640, 400]);

    var circle = d3.geo.greatCircle()
        .origin(projection.origin());

    var scale = {
      orthographic: 380,
      stereographic: 380,
      gnomonic: 380,
      equidistant: 380 / Math.PI * 2,
      equalarea: 380 / Math.SQRT2
    };

    var path = d3.geo.path()
        .projection(projection);

    var svg = d3.select("#bodyworld").append("svg:svg")
        .attr("width", 1280)
        .attr("height", 800)
        .on("mousedown", mousedown)
        .on("mousedown.drag", mousedown);

    d3.json("/json/world-countries.json", function(collection) {
        feature = svg.selectAll("path").data(collection.features).enter().append("svg:path").attr("d", clip).on("click", click);
        feature.append("svg:title").text(function(d) { return d.properties.name; });
    });

    d3.select(window)
        .on("mousemove", mousemove)
        .on("mouseup", mouseup);

    d3.select("select").on("change", function() {
      projection.mode(this.value).scale(scale[this.value]);
      refresh(750);
    });

    var m0,
        o0;

    function mousedown() {
      m0 = [d3.event.pageX, d3.event.pageY];
      o0 = projection.origin();
      d3.event.preventDefault();
    }

    function mousemove() {
      if (m0) {
        var m1 = [d3.event.pageX, d3.event.pageY],
            o1 = [o0[0] + (m0[0] - m1[0]) / 8, o0[1] + (m1[1] - m0[1]) / 8];
        projection.origin(o1);
        circle.origin(o1)
        refresh();
      }
    }

    function mouseup() {
      if (m0) {
        mousemove();
        m0 = null;
      }
    }

    function refresh(duration) {
      (duration ? feature.transition().duration(duration) : feature).attr("d", clip);
    }

    function clip(d) {
        return path(circle.clip(d));
    }

    function click(d) {
      window.location.href = '/sightings/country/' + d.id + '/' + d.properties.name;
    }
  </script>
</div>

<div class="w-full mt-6">
  <p class="text-gray-300">If you prefer, you can explore the latest sightings in your country using this list. Click on the names of the countries below</p>
</div>

<% cache("maps/content/countries/north_america") do %>
<div class="w-full mt-4">
  <p><strong class="text-[#D7DF21]">North America</strong><br/>
