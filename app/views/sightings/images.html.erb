<% cache("images/content", expires_in: 12.hours) do %>

<div class="px-4 md:px-12 max-w-[1920px] mx-auto py-10">

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="material-symbols-outlined text-[#D7DF21] text-3xl">photo_library</span>
      <h1 class="font-['Space_Grotesk'] text-2xl font-bold text-[#D7DF21] uppercase tracking-widest">UFO Image Gallery</h1>
    </div>
    <p class="text-[#dfe2eb] text-sm">Discover the latest UFO sightings images all over the world</p>
    <div class="h-px bg-gradient-to-r from-[#D7DF21]/40 via-[#484833]/30 to-transparent mt-4"></div>
  </div>

  <div class="my-6">
  </div>

  <!-- Image Grid -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
    <%
      unless @ufo_list.blank?
        @ufo_list.each do |ufo|
          image_urls = []
          image_urls, other_urls = select_url_images(ufo.links) unless ufo.links.blank?
          image_urls = image_urls + ufo.image_imagekit unless ufo.image_imagekit.blank?

          unless image_urls.blank?
            image_urls.each do |img|
              img_thumb = img
    %>
              <%= link_to sightings_search_path(id: ufo.id, title: friendly_title(ufo)), class: "group block relative aspect-video rounded-xl overflow-hidden border border-[#484833]/20 hover:border-[#D7DF21]/40 transition-all no-underline" do %>
                <img src="<%= img_thumb %>" alt="<%= ufo.location %>" loading="lazy" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#10141a]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute bottom-0 left-0 right-0 p-3 opacity-0 group-hover:opacity-100 transition-opacity">
                  <p class="text-[#D7DF21] font-['Space_Grotesk'] text-[10px] font-bold uppercase tracking-widest truncate"><%= ufo.location %></p>
                  <p class="text-[#c9c8ad] text-[10px]"><%= format_date ufo.sighted_at %></p>
                </div>
              <% end %>
    <%
            end
          end
        end
      end
    %>
  </div>

</div>

<div class="px-4 md:px-12 max-w-[1920px] mx-auto">
  <div class="my-6">
  </div>
</div>

<% end %>
