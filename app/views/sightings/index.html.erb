<!-- Hero Section -->
<section class="relative h-[600px] md:h-[750px] flex items-center justify-center overflow-hidden bg-[#0a0e14]">
  <div class="absolute inset-0 z-0 opacity-30">
    <div id="hero-map" class="w-full h-full"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#10141a]/30 to-[#10141a]"></div>
  </div>
  <div class="relative z-10 text-center max-w-4xl px-6">
    <div class="inline-flex items-center gap-2 mb-6 px-4 py-1 rounded-full border border-[#D7DF21]/30 bg-[#D7DF21]/5 text-[#D7DF21] font-['Space_Grotesk'] text-xs tracking-widest uppercase">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#D7DF21] opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[#D7DF21]"></span>
      </span>
      Live Data Feed Active
    </div>
    <h1 class="text-5xl md:text-8xl font-black mb-4 tracking-tighter leading-none text-[#dfe2eb]">
      <%= number_with_delimiter(num_reports) %> <span class="text-[#D7DF21] drop-shadow-[0_0_15px_rgba(215,223,33,0.3)]">SIGHTINGS</span>
    </h1>
    <p class="text-lg md:text-2xl text-[#c9c8ad] font-light mb-12 tracking-wide uppercase font-headline">
      Reported Datasets &hellip; and growing
    </p>
    <div class="flex flex-col md:flex-row items-center justify-center gap-4">
      <%= link_to sightings_ufosearch_path, class: "inline-flex items-center gap-3 bg-[#D7DF21] text-[#313300] px-8 py-4 rounded-xl font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-[#D7DF21]/80 transition-all no-underline" do %>
        <span class="material-symbols-outlined">radar</span>
        Search the Archive
      <% end %>
      <%= link_to new_report_path, class: "inline-flex items-center gap-3 bg-transparent border border-[#D7DF21]/30 text-[#D7DF21] px-8 py-4 rounded-xl font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-[#D7DF21]/10 transition-all no-underline" do %>
        <span class="material-symbols-outlined">upload_file</span>
        Report a Sighting
      <% end %>
    </div>
  </div>
  <!-- Side Decorations -->
  <div class="absolute left-6 top-1/2 -translate-y-1/2 hidden lg:flex flex-col gap-8 opacity-30">
    <div class="text-[10px] font-['Space_Grotesk'] text-[#bdf4ff] tracking-widest rotate-90 origin-left">LAT: 51.5074 N</div>
    <div class="text-[10px] font-['Space_Grotesk'] text-[#bdf4ff] tracking-widest rotate-90 origin-left">LONG: 0.1278 W</div>
  </div>
  <!-- Tactical Corners -->
  <div class="absolute top-24 left-8 w-24 h-24 border-t border-l border-[#D7DF21]/20 hidden lg:block"></div>
  <div class="absolute bottom-8 right-8 w-24 h-24 border-b border-r border-[#D7DF21]/20 hidden lg:block"></div>
</section>

<!-- Interactive Map Section -->
<section class="py-12 md:py-24 px-4 md:px-8 max-w-[1920px] mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 md:gap-8">
    <!-- Map -->
    <div class="lg:col-span-3 h-[500px] md:h-[700px] bg-[#0a0e14] rounded-xl relative overflow-hidden border border-[#484833]/20">
      <div id="sightings-map" class="w-full h-full"></div>
      <div class="absolute top-4 left-4 glass-panel p-4 rounded-lg border border-[#484833]/30 z-10">
        <h3 class="text-[#bdf4ff] font-headline text-sm font-bold tracking-widest uppercase">Global Surveillance</h3>
        <p class="text-[10px] text-[#c9c8ad]/70 mt-1 font-['Space_Grotesk']">REAL-TIME INTERCEPTS: <%= @ufo_list.size %> DISPLAYED</p>
      </div>
    </div>

    <!-- Recent Intercepts Sidebar -->
    <div class="flex flex-col gap-4 overflow-y-auto max-h-[700px] pr-2 custom-scrollbar" itemscope itemtype="http://schema.org/ItemList">
      <meta itemprop="itemListOrder" content="Descending"/>
      <h2 class="text-xs font-['Space_Grotesk'] uppercase tracking-[0.2em] text-[#c9c8ad] mb-2 px-2">Recent Intercepts</h2>

      <% @ufo_list.each_with_index do |ufo, i| %>
        <div class="p-4 bg-[#262a31] rounded-xl border-l-4 <%= i == 0 ? 'border-[#D7DF21]' : 'border-[#484833]/50' %> group hover:bg-[#31353c] transition-all cursor-pointer" itemprop="itemListElement" itemscope itemtype="http://schema.org/Article">
          <%= link_to sightings_search_path(id: ufo.id, title: friendly_title(ufo)), class: "no-underline block" do %>
            <div class="flex justify-between items-start mb-2">
              <span class="text-[#bdf4ff] font-headline text-[10px] font-bold tracking-widest"><%= format_date_microdata ufo.sighted_at %></span>
              <span class="text-[#c9c8ad]/40 text-[10px] font-['Space_Grotesk'] uppercase"><%= ufo.shape %></span>
            </div>
            <h4 itemprop="name" class="text-[#dfe2eb] font-headline font-bold text-sm tracking-tight mb-1 group-hover:text-[#D7DF21] transition-colors">
              <%= ufo.location.size > 35 ? ufo.location.partition("(")[0] : ufo.location %>
            </h4>
            <meta itemprop="datePublished" content="<%= format_date_microdata ufo.reported_at %>"/>
            <meta itemprop="headline" content="<%= friendly_title(ufo) %>"/>
            <p itemprop="dateCreated" content="<%= format_date_microdata ufo.sighted_at %>" class="text-xs text-[#c9c8ad]/70 leading-relaxed line-clamp-2 m-0">
              <%= ufo.description&.truncate(100) %>
            </p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Pagination -->
  <nav class="flex justify-center mt-8" aria-label="Pagination">
    <%== pagy_nav(@pagy) %>
  </nav>
</section>

<%= render partial: 'common/map', locals: {ufo_list: @ufo_list, map_id: 'sightings-map'} %>

<div class="my-5 px-4 md:px-8">
  <%= render partial: 'common/ads/horizontal_ad' %>
</div>

<!-- Glassmorphic Info Cards -->
<section class="py-16 md:py-24 px-4 md:px-8 bg-[#0a0e14]">
  <div class="max-w-[1400px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
    <!-- Card 1: Archives -->
    <div class="glass-panel p-8 rounded-2xl border border-[#484833]/20 relative group hover:border-[#D7DF21]/30 transition-all overflow-hidden">
      <div class="absolute -right-10 -top-10 opacity-5 group-hover:opacity-10 transition-opacity">
        <span class="material-symbols-outlined text-[160px]">database</span>
      </div>
      <div class="w-12 h-12 rounded-lg bg-[#D7DF21]/10 flex items-center justify-center mb-8 border border-[#D7DF21]/20">
        <span class="material-symbols-outlined text-[#D7DF21]">query_stats</span>
      </div>
      <h3 class="text-2xl font-headline font-bold text-[#dfe2eb] mb-4">THOUSANDS OF ARCHIVES</h3>
      <p class="text-[#c9c8ad]/80 text-sm leading-relaxed mb-8">Access our encrypted database of historical sightings. Filter by craft type, duration, and atmospheric conditions.</p>
      <%= link_to sightings_maps_path, class: "flex items-center gap-2 text-[#D7DF21] font-['Space_Grotesk'] text-xs tracking-widest uppercase hover:gap-4 transition-all no-underline" do %>
        ENTER VAULT <span class="material-symbols-outlined text-sm">arrow_forward</span>
      <% end %>
    </div>
    <!-- Card 2: Submit -->
    <div class="glass-panel p-8 rounded-2xl border border-[#484833]/20 relative group hover:border-[#bdf4ff]/30 transition-all overflow-hidden bg-gradient-to-br from-[#262a31] to-[#0a0e14]">
      <div class="absolute -right-10 -top-10 opacity-5 group-hover:opacity-10 transition-opacity">
        <span class="material-symbols-outlined text-[160px]">visibility</span>
      </div>
      <div class="w-12 h-12 rounded-lg bg-[#bdf4ff]/10 flex items-center justify-center mb-8 border border-[#bdf4ff]/20">
        <span class="material-symbols-outlined text-[#bdf4ff]">upload_file</span>
      </div>
      <h3 class="text-2xl font-headline font-bold text-[#dfe2eb] mb-4">SUBMIT INTEL</h3>
      <p class="text-[#c9c8ad]/80 text-sm leading-relaxed mb-8">Witnessed something unexplained? Your data is critical. Securely upload photos, videos, and witness testimony.</p>
      <%= link_to new_report_path, class: "flex items-center gap-2 text-[#bdf4ff] font-['Space_Grotesk'] text-xs tracking-widest uppercase hover:gap-4 transition-all no-underline" do %>
        FILE REPORT <span class="material-symbols-outlined text-sm">arrow_forward</span>
      <% end %>
    </div>
    <!-- Card 3: Images -->
    <div class="glass-panel p-8 rounded-2xl border border-[#484833]/20 relative group hover:border-[#D7DF21]/30 transition-all overflow-hidden">
      <div class="absolute -right-10 -top-10 opacity-5 group-hover:opacity-10 transition-opacity">
        <span class="material-symbols-outlined text-[160px]">photo_camera</span>
      </div>
      <div class="w-12 h-12 rounded-lg bg-[#D7DF21]/10 flex items-center justify-center mb-8 border border-[#D7DF21]/20">
        <span class="material-symbols-outlined text-[#D7DF21]">photo_library</span>
      </div>
      <h3 class="text-2xl font-headline font-bold text-[#dfe2eb] mb-4">IMAGE GALLERY</h3>
      <p class="text-[#c9c8ad]/80 text-sm leading-relaxed mb-8">Browse photographs and visual evidence captured by witnesses around the world. Hundreds of images of unexplained aerial phenomena.</p>
      <%= link_to sightings_images_path, class: "flex items-center gap-2 text-[#D7DF21] font-['Space_Grotesk'] text-xs tracking-widest uppercase hover:gap-4 transition-all no-underline" do %>
        VIEW GALLERY <span class="material-symbols-outlined text-sm">arrow_forward</span>
      <% end %>
    </div>
  </div>
</section>
