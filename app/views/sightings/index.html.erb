
<div class="grid grid-cols-12 gap-4">
  <div class="col-span-12 md:col-span-4">
    <h1 class="text-xl font-bold text-[#D7DF21]">Recent UFO Activity</h1>
    <p class="text-gray-300">Latest UFO sightings all over the world</p>
  </div>
  <div class="col-span-12 md:col-span-8">
    <%= render partial: 'common/gcs' %>
  </div>
</div>

<div class="w-full mt-6">
  <div itemscope itemtype="http://schema.org/ItemList">
    <meta itemprop="itemListOrder" content="Descending"/>

    <div class="bg-[#1D1D1D] border border-gray-700 rounded-lg p-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <% @ufo_list.each do |ufo| %>
          <div class="p-2" itemprop="itemListElement" itemscope itemtype="http://schema.org/Article">
            <div class="w-[85%] ml-auto mb-4">
              <p itemprop="name" class="overflow-hidden text-ellipsis font-bold text-sm mb-0">
                <%= ufo.location.size > 40 ? ufo.location.partition("(")[0] : ufo.location %>
              </p>
              <p itemprop="dateCreated" content="<%= format_date_microdata ufo.sighted_at %>" class="mb-0 text-gray-400"><%= format_date ufo.sighted_at %></p>
              <meta itemprop="datePublished" content="<%= format_date_microdata ufo.reported_at %>"/>
              <meta itemprop="headline" content="<%= friendly_title(ufo) %>"/>
              <p class="mb-0"><%= link_to "View sighting", sightings_search_path(id: ufo.id, title: friendly_title(ufo)), class: "text-[#D7DF21] hover:underline" %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Pagination -->
    <nav class="flex justify-center mt-6" aria-label="Pagination">
      <%== pagy_nav(@pagy) %>
    </nav>

  </div>
</div>

<div class="w-full mt-6">
  <div id="sightings-map" class="w-full h-[600px] rounded-lg"></div>
</div>

<%= render partial: 'common/map', locals: {ufo_list: @ufo_list, map_id: 'sightings-map'} %>

<div class="my-5">
  <%= render partial: 'common/ads/horizontal_ad' %>
</div>

<div class="w-full">
  <p class="text-gray-400 text-base my-2.5 pr-2.5">The map above shows the latest <strong class="text-gray-200">UFO sightings all over the world</strong>. Click the icons to get a summary of the sighting and access to the detail view, where you'll find the <strong class="text-gray-200">full report as it was reported by witnesses</strong> and <strong class="text-gray-200">other near sightings</strong>.</p>
  <p class="text-gray-400 text-base my-2.5 pr-2.5">If you find something interesting <strong class="text-gray-200">feel free to share it with your friends !!!</strong></p>
</div>

<% cache("index/modules") do %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
  <div class="text-center mt-4">
    <%= image_tag image_path('world.png'), class: "mx-auto", loading: "lazy", alt: "UFO sightings world map" %>
    <h3 class="text-lg font-bold mt-3"><%= link_to "Thousands of sightings", sightings_maps_path, class: "text-[#D7DF21] hover:underline" %></h3>
    <p class="text-gray-400 text-base my-2.5 pr-2.5 leading-relaxed">Find sightings by date, shape, location or near you !! Browse over more than 100.000 sightings.</p>
  </div>
  <div class="text-center mt-4">
    <%= image_tag image_path('ufo.png'), class: "mx-auto", loading: "lazy", alt: "Report a UFO sighting" %>
    <h3 class="text-lg font-bold mt-3"><%= link_to "Have you seen a UFO?", new_report_path, class: "text-[#D7DF21] hover:underline" %></h3>
    <p class="text-gray-400 text-base my-2.5 pr-2.5 leading-relaxed">Be quiet, you are not alone. Thousands of people have experienced the same before.</p>
  </div>
  <div class="text-center mt-4">
    <%= image_tag image_path('android.png'), class: "mx-auto", loading: "lazy", alt: "UFO Hunters Android app" %>
    <h3 class="text-lg font-bold mt-3"><%= link_to "UFO Hunters App", "https://play.google.com/store/apps/details?id=com.ufohunters.sightings", class: "text-[#D7DF21] hover:underline" %></h3>
    <p class="text-gray-400 text-base my-2.5 pr-2.5 leading-relaxed">Download our App and take a look at the most recent sightings, or those near you.</p>
  </div>
</div>
<% end %>
