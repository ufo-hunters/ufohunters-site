
<!-- Region Header -->
<section class="px-4 md:px-12 max-w-[1920px] mx-auto pt-10 pb-6">
  <p class="uppercase tracking-widest text-[10px] font-['Space_Grotesk'] text-[#bdf4ff] mb-2">Regional Sightings</p>
  <h3 class="text-3xl md:text-4xl font-bold font-['Space_Grotesk'] uppercase tracking-widest text-[#D7DF21] drop-shadow-[0_0_8px_rgba(215,223,33,0.5)]">Asia</h3>
</section>

<!-- Sightings Map -->
<section class="px-4 md:px-12 max-w-[1920px] mx-auto mb-6">
  <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-4">
    <div id="sightings-map" class="w-full h-[550px] rounded-lg overflow-hidden"></div>
  </div>
</section>

<%= render partial: 'common/map', locals: {ufo_list: @ufo_list, map_id: 'sightings-map', map_zoom: 2, map_center: [83.64,28.24]} %>

<div class="px-4 md:px-12 max-w-[1920px] mx-auto my-5">
  <%= render partial: 'common/ads/horizontal_ad' %>
</div>

<!-- Latest Sightings -->
<section class="px-4 md:px-12 max-w-[1920px] mx-auto pb-10">
  <div class="mb-6 border-l-4 border-[#D7DF21] pl-4">
    <p class="uppercase tracking-widest text-[10px] font-['Space_Grotesk'] text-[#c9c8ad] mb-1">Database</p>
    <h3 class="text-xl font-bold font-['Space_Grotesk'] uppercase tracking-widest text-[#dfe2eb]">100 Latest UFO Sightings</h3>
  </div>

  <div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 lg:col-span-8">
      <%= render partial: 'common/latest_sightings' %>
    </div>
    <div class="col-span-12 lg:col-span-4">
      <%= render partial: 'common/ads/adaptable3' %>
    </div>
  </div>
</section>
