
<div class="px-4 md:px-12 max-w-[1920px] mx-auto py-10">

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="material-symbols-outlined text-[#D7DF21] text-3xl">terminal</span>
      <h2 class="font-['Space_Grotesk'] text-2xl font-bold text-[#D7DF21] uppercase tracking-widest">UFO Research Team</h2>
    </div>
    <div class="h-px bg-gradient-to-r from-[#D7DF21]/40 via-[#484833]/30 to-transparent mt-4"></div>
  </div>

  <!-- Info -->
  <div class="bg-[#262a31] border border-[#484833]/20 rounded-xl p-6 mb-8">
    <div class="text-[#dfe2eb] space-y-2 text-sm leading-relaxed">
      <p>Do you want to join our research team?.</p>
      <p>We have several collaborators that publish their research in the form of articles on our site. In the navigation menu you can see a tab called "Articles".</p>
      <p>If you want to publish your research and findings and share them with the whole world, create your account on our site, create your articles and show the world what you know.</p>
    </div>
  </div>

  <div class="flex flex-col md:flex-row gap-8">

    <!-- Login card -->
    <div class="flex-1 bg-[#262a31] border border-[#484833]/20 rounded-xl p-8">
      <div class="flex items-center gap-2 mb-6">
        <span class="material-symbols-outlined text-[#bdf4ff] text-xl">login</span>
        <h3 class="font-['Space_Grotesk'] text-sm font-bold text-[#D7DF21] uppercase tracking-widest">Log in</h3>
      </div>
      <%= form_tag sessions_path do %>
        <div class="mb-5">
          <label for="username" class="font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block">Username</label>
          <%= text_field_tag :username, params[:username], class: "w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none" %>
        </div>
        <div class="mb-5">
          <label for="password" class="font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block">Password</label>
          <%= password_field_tag :password, nil, class: "w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none" %>
        </div>
        <div><%= submit_tag "Log in", class: "bg-[#D7DF21] text-[#313300] hover:bg-[#D7DF21] font-['Space_Grotesk'] uppercase tracking-widest font-bold py-3 px-8 rounded-lg cursor-pointer transition-colors duration-200" %></div>
      <% end %>

      <% flash.each do |name, msg| %>
        <%= content_tag :div, msg, :id => "flash#{name}", :class => "mt-4 bg-red-950/40 border border-red-700/50 text-red-300 px-4 py-3 rounded-lg text-sm" %>
      <% end %>
    </div>

    <!-- Sign up card -->
    <div class="flex-1 bg-[#262a31] border border-[#484833]/20 rounded-xl p-8">
      <div class="flex items-center gap-2 mb-6">
        <span class="material-symbols-outlined text-[#bdf4ff] text-xl">person_add</span>
        <h3 class="font-['Space_Grotesk'] text-sm font-bold text-[#D7DF21] uppercase tracking-widest">Sign up</h3>
      </div>

      <% @user ||= User.new %>
      <%= form_for @user do |f| %>
        <div class="mb-5">
          <%= f.label :username, nil, class: "font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block" %>
          <%= f.text_field :username, class: "w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none" %>
        </div>
        <div class="mb-5">
          <%= f.label :password, nil, class: "font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block" %>
          <%= f.password_field :password, class: "w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none" %>
        </div>
        <div class="mb-5">
          <%= f.label :password_confirmation, nil, class: "font-['Space_Grotesk'] text-xs uppercase tracking-widest text-[#c9c8ad] mb-2 block" %>
          <%= f.password_field :password_confirmation, class: "w-full bg-[#0a0e14] border border-[#484833]/30 text-[#dfe2eb] focus:ring-1 focus:ring-[#D7DF21] rounded-lg px-4 py-3 focus:outline-none" %>
        </div>
        <div class="mb-5">
          <% if ENV['RECAPTCHA_SITE_KEY'].present? %>
            <%= recaptcha_tags %>
          <% else %>
            <p class="text-[#D7DF21]/60 text-sm">[reCAPTCHA disabled]</p>
          <% end %>
          <div class="mt-2"><span class="text-red-400 text-sm"><%= flash[:recaptcha_error] %></span></div>
        </div>
        <div><%= submit_tag "Sign up", class: "bg-[#D7DF21] text-[#313300] hover:bg-[#D7DF21] font-['Space_Grotesk'] uppercase tracking-widest font-bold py-3 px-8 rounded-lg cursor-pointer transition-colors duration-200" %></div>
      <% end %>

      <% flash.each do |name, msg| %>
        <%= content_tag :div, msg, :id => "flash#{name}", :class => "mt-4 bg-red-950/40 border border-red-700/50 text-red-300 px-4 py-3 rounded-lg text-sm" %>
      <% end %>
    </div>

  </div>

  <div class="mt-8">
    <%= render partial: 'common/ads/horizontal_ad' %>
  </div>

</div>
