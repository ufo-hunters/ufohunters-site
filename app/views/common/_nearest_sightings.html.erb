<%
cache_unless(@nearest_sightings.blank?, "common/partials/nearest_sightings/#{@nearest_sightings.hash}", expires_in: 12.hours) do
%>

          <script language="javascript">
                $(document).ready(function() {
				    $('#tabledata').DataTable(
				    	{
		    				 "order": [[ 1, "desc" ]]
				        }

				    )});

          </script>

                <div class="mt-5 mb-5">
		     		  <h3 class="text-xl font-semibold text-[#D7DF21] mb-3">Top 100 nearest sightings ordered by sighting date (100 miles radius):</h3>

				      <table id="tabledata" class="w-full text-left text-gray-300 text-sm" itemscope itemtype="http://schema.org/ItemList">
				      		<thead class="bg-gray-800 text-[#D7DF21] uppercase text-xs">
								<tr>
										<th class="px-4 py-3">Location
										</th>
										<th class="px-4 py-3">Sighted on
										</th>
										<th class="px-4 py-3">Shape
										</th>
										<th class="px-4 py-3 hidden sm:table-cell">Duration
										</th>
							  	</tr>
							</thead>
							<tfoot class="bg-gray-800 text-[#D7DF21] uppercase text-xs">
								<tr>
										<th class="px-4 py-3">Location
										</th>
										<th class="px-4 py-3">Sighted on
										</th>
										<th class="px-4 py-3">Shape
										</th>
										<th class="px-4 py-3 hidden sm:table-cell">Duration
										</th>
							  	</tr>
							</tfoot>
							<tbody class="divide-y divide-gray-700">
							   	<%
							   	# In order to avoid the same sighting as nearest sighting
							   	@nearest_sightings.each do |sighting|
							    	if ufo_id == sighting.id
							       	next
							     	end
									%>
			  		   			<tr class="hover:bg-gray-800/50 transition" itemprop="itemListElement" itemscope itemtype="http://schema.org/Article">
						       		<td class="px-4 py-3">
						       			<meta itemprop="datePublished" content="<%= format_date_microdata sighting.reported_at %>"/>
									  	<meta itemprop="headline" content="<%= friendly_title(sighting) %>"/>
						       			<span itemprop="name"><%= link_to sighting.location, {:controller => "sightings", :action => "search", :id => sighting.id, :title => friendly_title(sighting)}, class: "text-[#D7DF21] hover:underline" %></span>
						       		</td>
						       		<td itemprop="dateCreated" content="<%= format_date_microdata sighting.sighted_at %>" class="px-4 py-3">
							    			<%= format_date_microdata sighting.sighted_at %>
							    		</td>
							    		<td class="px-4 py-3">
							    			<%=sighting.shape%>
						       		</td>
						       		<td class="px-4 py-3 hidden sm:table-cell">
							    			<%= sighting.duration %>
						       		</td>
										</tr>
								  <%
								  end
								  %>
							  </tbody>
					 </table>
			    </div>
<%
end
%>
