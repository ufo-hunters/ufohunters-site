<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= @page_title %> - UFO Hunters</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'ufo-green': '#D7DF21',
            'ufo-green-dark': '#959C16',
            'ufo-green-hover': '#7D8212',
            'ufo-dark': '#1D1D1D',
          }
        }
      }
    }
  </script>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="keywords" content="UFO, UFO Sightings, UFO Activity, Latest UFO Activity, Latest UFO Sightings, Recent UFO Activity, Recent UFO Sightings, UFO stats, UFO Reports, Latest UFO Reports, Recent UFO Reports, UFO Maps, UFO Hunters, UFO Videos, UFO Sightings Videos, UFO Sightings Reports">
  <meta name="description" content="<%= @page_description %>">
  <link rel="canonical" href="<%= request.original_url.split('?').first %>" />
  <% if defined?(@pagy) && @pagy.prev %>
    <link rel="prev" href="<%= url_for(page: @pagy.prev) %>" />
  <% end %>
  <% if defined?(@pagy) && @pagy.next %>
    <link rel="next" href="<%= url_for(page: @pagy.next) %>" />
  <% end %>
  <meta property="og:title" content="<%= @page_title %> - UFO Hunters" />
  <meta property="og:description" content="<%= @page_description %>" />
  <meta property="og:url" content="<%= request.original_url.split('?').first %>" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="UFO Hunters" />
  <meta property="og:image" content="<%= @og_image || image_url('ufo-hunters-logo.png') %>" />
  <meta property="twitter:card" content="summary">
  <meta property="twitter:site" content="@UfoHuntersCom">
  <meta property="twitter:title" content="<%= @page_title %> - UFO Hunters">
  <meta property="twitter:description" content="<%= @page_description %>">
  <meta property="twitter:image" content="<%= @og_image || image_url('ufo-hunters-logo.png') %>">
  <link href="<%= image_path('platillo_verde.ico') %>" rel="shortcut icon">
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet">
  <style>
    #map { position: absolute; top: 0; bottom: 0; width: 100%; }
    .marker {
      background-image: url('<%= image_path('platillo_verde.png') %>');
      background-size: cover;
      width: 29px;
      height: 25px;
      border-radius: 50%;
      cursor: pointer;
    }
    .maplibregl-popup-content {
      text-align: left;
      font-family: 'Open Sans', sans-serif;
      padding: 10px;
    }
    .maplibregl-popup-content h3 {
      font-size: 100%;
      padding-top: 0;
      margin: 0 10px 5px 0;
    }
  </style>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "UFO Hunters",
    "url": "https://www.ufo-hunters.com",
    "description": "Community-driven platform for reporting and browsing UFO sightings worldwide",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://www.ufo-hunters.com/sightings/ufosearch?location={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "UFO Hunters",
    "url": "https://www.ufo-hunters.com",
    "logo": "https://www.ufo-hunters.com/assets/ufo-hunters-logo.png",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "ufohunterscom@gmail.com",
      "contactType": "customer support"
    },
    "sameAs": [
      "https://twitter.com/UfoHuntersCom",
      "https://www.facebook.com/UfoHuntersCom",
      "https://play.google.com/store/apps/details?id=com.ufohunters.sightings"
    ]
  }
  </script>
</head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-4FL7V9G39W"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-4FL7V9G39W');
</script>
<body itemscope itemtype="http://schema.org/WebPage" class="bg-white">

  <div class="max-w-7xl mx-auto px-4">
    <!-- Header -->
    <header itemscope itemtype="http://schema.org/WPHeader" class="hidden sm:flex items-center justify-between py-4">
      <div class="flex-shrink-0">
        <div class="m-0"><a itemprop="url" href="/"><span itemprop="name"><%= image_tag 'ufo-hunters-logo.png', alt: 'UFO Hunters' %></span></a></div>
      </div>
      <div>
        <h2 class="text-lg font-semibold mt-0"><%= num_reports %> sightings reported...<br>and growing</h2>
      </div>
      <div>
        <h5 class="text-[#d7df21] text-sm font-semibold">
          <%= link_to "Do you want to join our UFO research team?", articles_uforesearchteam_path %>
        </h5>
      </div>
    </header>

    <!-- Navbar -->
    <nav class="bg-[#D7DF21] rounded-lg mb-4" data-controller="navbar" itemscope itemtype="http://schema.org/SiteNavigationElement">
      <div class="flex items-center justify-between px-4 py-2 sm:hidden">
        <a href="/" class="sm:hidden"><%= image_tag 'ufo-hunters-logo.png', alt: 'UFO Hunters', class: 'h-8' %></a>
        <button data-action="click->navbar#toggle" class="p-2 rounded bg-[#BBC31C] text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
      <ul id="menunew" class="hidden sm:flex flex-wrap items-center gap-1 px-4 py-2 font-bold text-sm text-gray-900 list-none m-0" data-navbar-target="menu">
        <% menu_items = [
          ["Home", root_path, "index"],
          ["Articles", articles_path, "articles"],
          ["UFOs Search", sightings_ufosearch_path, "ufosearch"],
          ["Statistics", stats_path, "statistics"],
          ["Maps", sightings_maps_path, "maps"],
          ["Report a UFO", new_report_path, "report"],
          ["Videos", sightings_videos_path, "videos"],
          ["Images", sightings_images_path, "images"],
          ["About us", sightings_about_path, "about"],
          ["UFO Research Team", articles_uforesearchteam_path, "uforesearchteam"]
        ] %>
        <% menu_items.each do |label, path, key| %>
          <li>
            <%= link_to label, path, class: "block px-3 py-1 rounded-full no-underline #{@menu == key ? 'bg-white text-gray-900' : 'text-gray-900 hover:bg-[#BBC31C]'}", itemprop: "url" %>
          </li>
        <% end %>
        <% if logged_in? %>
          <li><%= link_to "My space", articles_myspace_path, class: "block px-3 py-1 rounded-full no-underline text-green-700 hover:bg-[#BBC31C]" %></li>
          <li><%= link_to "Logout", sessions_destroy_path, class: "block px-3 py-1 rounded-full no-underline text-green-700 hover:bg-[#BBC31C]" %></li>
        <% end %>
      </ul>
    </nav>

    <!-- Main content -->
    <main>
      <%= yield %>
    </main>

    <!-- Video thumbnails carousel -->
    <% cache("common/video_carousel", expires_in: 12.hours) do %>
    <div class="bg-[#D7DF21] mt-12 p-4 rounded-lg" itemscope itemtype="http://schema.org/ItemList">
      <meta itemprop="itemListOrder" content="Descending">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <% video_list.first(8).each do |thumb| %>
          <% thumb.links&.each do |link| %>
            <% if youtube_link?(link) %>
              <% video_id = youtube_video_id(link) %>
              <% if video_id %>
                <div class="text-center" itemprop="itemListElement" itemscope itemtype="http://schema.org/VideoObject">
                  <h4 itemprop="name" class="text-sm font-semibold truncate" title="<%= thumb.location %>"><%= thumb.location %></h4>
                  <meta itemprop="description" content="<%= friendly_title(thumb) %>">
                  <p itemprop="dateCreated" content="<%= format_date_microdata thumb.sighted_at %>" class="text-xs"><%= format_date thumb.sighted_at %></p>
                  <meta itemprop="uploadDate" content="<%= format_date_microdata thumb.reported_at %>">
                  <meta itemprop="thumbnailUrl" content="<%= Ufo::THUMBS_URL_BASE + video_id + '/1.jpg' %>">
                  <figure>
                    <%= link_to sightings_search_path(id: thumb.id, title: friendly_title(thumb)) do %>
                      <%= image_tag Ufo::THUMBS_URL_BASE + video_id + "/1.jpg", itemprop: "image", class: "w-full rounded", alt: "UFO Sighting at #{thumb.location}", loading: "lazy" %>
                    <% end %>
                  </figure>
                </div>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
    <% end %>

    <!-- Footer -->
    <footer class="footer mt-8 rounded-lg p-6" itemscope itemtype="http://schema.org/WPFooter">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>&copy; <%= Date.today.strftime("%Y") %> ufo-hunters.com</div>

        <div class="flex gap-4">
          <button onclick="document.getElementById('disclaimerModal').classList.remove('hidden')" class="text-[#D7DF21] underline cursor-pointer bg-transparent border-none">Disclaimer</button>
          <button onclick="document.getElementById('privacyModal').classList.remove('hidden')" class="text-[#D7DF21] underline cursor-pointer bg-transparent border-none">Privacy Policy</button>
        </div>

        <div class="flex gap-3">
          <a href="mailto:ufohunterscom@gmail.com" class="text-[#D7DF21] text-2xl">&#9993;</a>
          <a href="https://www.facebook.com/UfoHuntersCom" target="_blank" class="text-[#D7DF21] text-xl">FB</a>
          <a href="https://twitter.com/UfoHuntersCom" target="_blank" class="text-[#D7DF21] text-xl">X</a>
        </div>

        <div>
          <a href="https://play.google.com/store/apps/details?id=com.ufohunters" class="text-white font-bold">
            Android App
          </a>
        </div>
      </div>
    </footer>

    <!-- Disclaimer Modal -->
    <div id="disclaimerModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
      <div class="bg-white rounded-lg p-6 max-w-lg mx-4">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-bold text-gray-900 mt-0">Disclaimer</h3>
          <button onclick="document.getElementById('disclaimerModal').classList.add('hidden')" class="text-gray-500 hover:text-gray-900 text-2xl bg-transparent border-none cursor-pointer">&times;</button>
        </div>
        <p class="text-gray-900 text-sm mb-2">The information on this site that is not produced by ufo-hunters.com is covered under the <strong><a href="http://www.copyright.gov/fls/fl102.html" target="_blank">Copyright Disclaimer Under Section 107 of the Copyright Act 1976</a></strong></p>
        <p class="text-gray-900 text-sm">The views, opinions, and facts expressed on this web site are solely those of the original authors, witnesses and other contributors. These views and opinions do not necessarily represent those of ufo-hunters.com staff, and/or any/all contributors to this site.</p>
        <div class="mt-4 text-right">
          <button onclick="document.getElementById('disclaimerModal').classList.add('hidden')" class="btn-primary">Close</button>
        </div>
      </div>
    </div>

    <!-- Privacy Modal -->
    <div id="privacyModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
      <div class="bg-white rounded-lg p-6 max-w-lg mx-4">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-bold text-gray-900 mt-0">Privacy Policy</h3>
          <button onclick="document.getElementById('privacyModal').classList.add('hidden')" class="text-gray-500 hover:text-gray-900 text-2xl bg-transparent border-none cursor-pointer">&times;</button>
        </div>
        <p class="text-gray-900 text-sm mb-2"><strong>ufo-hunters.com</strong> does not require any personal information from you other than a valid email address, and is not responsible for any personal information you choose to share through reports, articles, comments or any kind of content.</p>
        <p class="text-gray-900 text-sm"><strong>ufo-hunters.com</strong> does not share your email address with third-parties, and is not responsible for the republishing of your contents (reports, pictures, videos, articles, comments) on other web sites.</p>
        <div class="mt-4 text-right">
          <button onclick="document.getElementById('privacyModal').classList.add('hidden')" class="btn-primary">Close</button>
        </div>
      </div>
    </div>

    <div class="h-24"></div>
  </div>

  <!-- Cookie consent -->
  <div data-controller="cookie-consent">
    <div data-cookie-consent-target="banner" class="hidden fixed bottom-0 left-0 right-0 bg-[#959C16] text-white text-sm z-40 px-4 py-3">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <p class="m-0">This site uses cookies and third-party cookies. When navigating or using our services, you agree to our use of them.
          <a href="#" data-action="click->cookie-consent#showPrivacy" class="text-white underline">More information</a>
        </p>
        <button data-action="click->cookie-consent#accept" class="ml-4 px-3 py-1 bg-white text-gray-900 rounded text-xs font-bold cursor-pointer border-none">Accept</button>
      </div>
    </div>
    <div data-cookie-consent-target="privacy" class="hidden fixed bottom-1/4 left-4 right-4 sm:left-auto sm:right-4 sm:w-96 bg-[#959C16] text-white text-sm z-50 p-4 rounded-lg">
      <button data-action="click->cookie-consent#hidePrivacy" class="absolute top-2 right-2 text-white text-lg bg-transparent border-none cursor-pointer">&times;</button>
      <p class="font-bold mb-2">PRIVACY POLICY:</p>
      <p class="text-xs">We are committed to protecting your privacy. This webpage displays Google Ads which uses cookies to serve ads based on prior visits. You may opt out via <a href="https://www.google.com/ads/preferences/" target="_blank" class="text-white underline">Ads Settings</a>. Contact: ufohunterscom@gmail.com</p>
    </div>
  </div>
</body>
</html>
